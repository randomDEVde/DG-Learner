{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DG Learner",
  "version": "0.1.5",
  "identifier": "de.bwi.dgranks.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "DG Learner",
        "width": 1440,
        "height": 960,
        "minWidth": 1024,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage", "dmg", "nsis"],
    "category": "Education",
    "publisher": "Konrad Schmitz",
    "homepage": "https://github.com/schmitzkonrad-hub/DG-Learner",
    "shortDescription": "Desktop-Lernanwendung für Bundeswehr-Dienstgrade",
    "longDescription": "Interaktive Desktop-Anwendung zum Trainieren von Bundeswehr-Dienstgraden mit lokaler Fortschrittsspeicherung.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/256x256.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0"
    },
    "linux": {
      "deb": {
        "depends": []
      }
    }
  }
}
